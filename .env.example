# StockOverflow Configuration
# Copy this file to .env and fill in your values

# Server
HOST=127.0.0.1
PORT=8000
DEBUG=true

# Data
DEFAULT_HISTORY_PERIOD=2y

# LLM (optional — configure via web UI at /)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2000

# Data sources (optional — for failover when yfinance is down)
# ALPHAVANTAGE_API_KEY=your-key-here
# TWELVEDATA_API_KEY=your-key-here
